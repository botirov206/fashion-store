# Local dev only (pnpm dev). Production Docker always binds host port 3010.
PORT=3010

# Admin dashboard credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
SESSION_SECRET=change-this-to-a-random-string
