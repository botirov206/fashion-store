# Neon / cloud PostgreSQL (recommended)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Local or Docker fallback (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fashiondb
DB_USER=fashion_user
DB_PASSWORD=fashion_pass_2026

# Host port (Docker maps HOST:3010 → container:3000). Use 3010 if port 3000 is taken.
PORT=3010

# Admin dashboard credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
SESSION_SECRET=change-this-to-a-random-string
